<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory
        app:title="@string/pref_header_general"
        app:iconSpaceReserved="false">

        <SwitchPreferenceCompat
            app:key="call_recording"
            app:title="@string/pref_call_recording_name"
            app:summary="@string/pref_call_recording_desc"
            app:iconSpaceReserved="false" />

        <Preference
            app:key="record_rules"
            app:persistent="false"
            app:title="@string/pref_record_rules_name"
            app:summary="@string/pref_record_rules_desc"
            app:iconSpaceReserved="false" />

        <com.chiller3.bcr.view.LongClickablePreference
            app:key="output_dir"
            app:persistent="false"
            app:title="@string/pref_output_dir_name"
            app:summary="@string/pref_output_dir_desc"
            app:iconSpaceReserved="false" />

        <Preference
            app:key="output_format"
            app:persistent="false"
            app:title="@string/pref_output_format_name"
            app:summary="@string/pref_output_format_desc"
            app:iconSpaceReserved="false" />

        <Preference
            app:key="min_duration"
            app:persistent="false"
            app:title="@string/pref_min_duration_name"
            app:iconSpaceReserved="false" />

        <SwitchPreferenceCompat
            app:key="write_metadata"
            app:title="@string/pref_write_metadata_name"
            app:summary="@string/pref_write_metadata_desc"
            app:iconSpaceReserved="false" />

        <SwitchPreferenceCompat
            app:key="record_telecom_apps"
            app:title="@string/pref_record_telecom_apps_name"
            app:summary="@string/pref_record_telecom_apps_desc"
            app:iconSpaceReserved="false" />

        <SwitchPreferenceCompat
            app:key="record_dialing_state"
            app:title="@string/pref_record_dialing_state_name"
            app:summary="@string/pref_record_dialing_state_desc"
            app:iconSpaceReserved="false" />

        <SwitchPreferenceCompat
            app:key="notification_open_dir"
            app:title="@string/pref_notification_open_dir_name"
            app:summary="@string/pref_notification_open_dir_desc"
            app:iconSpaceReserved="false" />

        <SwitchPreferenceCompat
            app:key="show_launcher_icon"
            app:persistent="false"
            app:title="@string/pref_show_launcher_icon_name"
            app:summary="@string/pref_show_launcher_icon_desc"
            app:iconSpaceReserved="false" />

    </PreferenceCategory>

    <PreferenceCategory
        app:key="realtime_bridge"
        app:title="Realtime Bridge"
        app:iconSpaceReserved="false">

        <SwitchPreferenceCompat
            app:key="enable_realtime_bridge"
            app:title="Bật Realtime Bridge"
            app:summary="Cho phép stream PCM hai chiều khi có cuộc gọi active"
            app:defaultValue="false"
            app:iconSpaceReserved="false" />

        <EditTextPreference
            app:key="realtime_out_url"
            app:title="Output WebSocket URL"
            app:summary="URL để gửi PCM từ điện thoại → web (dt1 → server → browser)"
            app:defaultValue="ws://192.168.1.100:8081/ws?session=call-test"
            android:inputType="textUri"
            app:dependency="enable_realtime_bridge"
            app:useSimpleSummaryProvider="true"
            app:iconSpaceReserved="false" />

        <EditTextPreference
            app:key="realtime_in_url"
            app:title="Input WebSocket URL"
            app:summary="URL nhận PCM từ web → điện thoại (tương lai)"
            app:defaultValue="ws://192.168.1.100:8081/ws?session=call-test"
            android:inputType="textUri"
            app:dependency="enable_realtime_bridge"
            app:enabled="false"
            app:useSimpleSummaryProvider="true"
            app:iconSpaceReserved="false" />

        <EditTextPreference
            app:key="control_url"
            app:title="Control / Signaling URL"
            app:summary="URL cho hello, session management, auth (tương lai)"
            app:defaultValue="ws://192.168.1.100:8081/ws?session=call-test"
            android:inputType="textUri"
            app:enabled="false"
            app:useSimpleSummaryProvider="true"
            app:iconSpaceReserved="false" />

        <EditTextPreference
            app:key="device_id"
            app:title="Device ID"
            app:summary="ID để phân biệt dt1 trên server"
            app:defaultValue="a51-root"
            app:dependency="enable_realtime_bridge"
            app:useSimpleSummaryProvider="true"
            app:iconSpaceReserved="false" />

        <EditTextPreference
            app:key="playback_mode"
            app:title="Playback mode"
            app:summary="local"
            app:defaultValue="local"
            app:dependency="enable_realtime_bridge"
            app:useSimpleSummaryProvider="true"
            app:iconSpaceReserved="false" />

        <EditTextPreference
            app:key="inject_mode"
            app:title="Inject mode"
            app:summary="noop"
            app:defaultValue="noop"
            app:dependency="enable_realtime_bridge"
            app:useSimpleSummaryProvider="true"
            app:iconSpaceReserved="false" />

        <EditTextPreference
            app:key="auth_token"
            app:title="Authorization Token"
            app:summary="Token để xác thực với server (nếu cần)"
            app:enabled="false"
            app:iconSpaceReserved="false" />

    </PreferenceCategory>

    <PreferenceCategory
        app:title="@string/pref_header_about"
        app:iconSpaceReserved="false">

        <com.chiller3.bcr.view.LongClickablePreference
            app:key="version"
            app:persistent="false"
            app:title="@string/pref_version_name"
            app:iconSpaceReserved="false" />

    </PreferenceCategory>

    <PreferenceCategory
        app:key="debug"
        app:title="@string/pref_header_debug"
        app:iconSpaceReserved="false">

        <SwitchPreferenceCompat
            app:key="force_direct_boot"
            app:title="@string/pref_force_direct_boot_name"
            app:summary="@string/pref_force_direct_boot_desc"
            app:iconSpaceReserved="false" />

        <Preference
            app:key="migrate_direct_boot"
            app:persistent="false"
            app:title="@string/pref_migrate_direct_boot_name"
            app:summary="@string/pref_migrate_direct_boot_desc"
            app:iconSpaceReserved="false" />

        <Preference
            app:key="save_logs"
            app:persistent="false"
            app:title="@string/pref_save_logs_name"
            app:summary="@string/pref_save_logs_desc"
            app:iconSpaceReserved="false" />

    </PreferenceCategory>

</PreferenceScreen>